{
	"name": "obsidian-smart-sync",
	"version": "0.1.0",
	"description": "Sync your Obsidian vault bidirectionally with cloud storage backends.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.35",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"fake-indexeddb": "^6.2.5",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"node-diff3": "^3.2.0",
		"obsidian": "latest"
	}
}
